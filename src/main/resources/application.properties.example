# ==================== SERVER ====================
server.port=8081

# ==================== SPRING ====================
spring.application.name=FreshFarmJuba
spring.profiles.active=dev

# ==================== DATASOURCE ====================
spring.datasource.url=jdbc:postgresql://localhost:5432/freshfarmjuba
spring.datasource.username=${DB_USERNAME:postgres}
spring.datasource.password=${DB_PASSWORD:default_password} # Use a variable
spring.datasource.driver-class-name=org.postgresql.Driver

# IMPORTANT: Ensure data.sql runs
spring.sql.init.mode=always
spring.jpa.defer-datasource-initialization=true

# ==================== JPA ====================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true

# ==================== THYMELEAF ====================
spring.thymeleaf.cache=false
spring.thymeleaf.prefix=classpath:/templates/
spring.thymeleaf.suffix=.html
spring.thymeleaf.encoding=UTF-8

# ==================== LOGGING ====================
logging.level.org.springframework.security=DEBUG
logging.level.com.example.freshfarmjuba=DEBUG

# ==================== EMAIL CONFIGURATION ====================
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=${EMAIL_USERNAME:simonlodule18@gmail.com}
spring.mail.password=${EMAIL_PASSWORD:ctyq dpnd uptk chtv}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# ==================== FILE UPLOAD ====================
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# Static resources configuration
spring.web.resources.static-locations=classpath:/static/
spring.mvc.static-path-pattern=/**

# Thymeleaf Configuration
spring.thymeleaf.mode=HTML
spring.thymeleaf.servlet.content-type=text/html
